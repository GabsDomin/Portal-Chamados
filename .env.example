PORT=4173
TOPDESK_BASE_URL=https://keep-sottelli.topdesk.net
TOPDESK_USERNAME=usuario_api
TOPDESK_APP_PASSWORD=app_password_ou_token
TOPDESK_OPERATOR_GROUP_ID=
TOPDESK_CALL_TYPE_ID=
TOPDESK_ENTRY_TYPE_ID=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Prisma + Supabase (preencha [YOUR-PASSWORD] com a senha do banco)
# Pooler transaction mode — usado pelo app em runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Pooler session mode — usado pelo Prisma CLI (migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Aliases aceitos na Railway, caso voce ja tenha criado com esses nomes:
# URL_DO_BANCO_DE_DADOS -> DATABASE_URL
# URL_DIRETA -> DIRECT_URL
# URL_SUPABASE -> SUPABASE_URL
# URL_BASE_TOPDESK -> TOPDESK_BASE_URL
# SENHA_TOPDESK_APP -> TOPDESK_APP_PASSWORD
